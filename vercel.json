{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/cursos",
      "destination": "/#cursos",
      "permanent": false
    },
    {
      "source": "/cursos/",
      "destination": "/#cursos",
      "permanent": false
    },
    {
      "source": "/inscripciones",
      "destination": "/#inscripciones",
      "permanent": false
    },
    {
      "source": "/inscripciones/",
      "destination": "/#inscripciones",
      "permanent": false
    },
    {
      "source": "/programa",
      "destination": "/#programa",
      "permanent": false
    },
    {
      "source": "/programa/",
      "destination": "/#programa",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/programa/descarga",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"PROGRAMA-ACM.pdf\""
        }
      ]
    },
    {
      "source": "/programa/descarga/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"PROGRAMA-ACM.pdf\""
        }
      ]
    },
    {
      "source": "/reglamento",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"REGLAMENTO-ACM.pdf\""
        }
      ]
    },
    {
      "source": "/reglamento/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"REGLAMENTO-ACM.pdf\""
        }
      ]
    },
    {
      "source": "/documentos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/programa/descarga",
      "destination": "/documentos/PROGRAMA-ACM.pdf"
    },
    {
      "source": "/programa/descarga/",
      "destination": "/documentos/PROGRAMA-ACM.pdf"
    },
    {
      "source": "/reglamento",
      "destination": "/documentos/REGLAMENTO-ACM.pdf"
    },
    {
      "source": "/reglamento/",
      "destination": "/documentos/REGLAMENTO-ACM.pdf"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
